import { Button, CheckBox, HorizontalBox, Slider } from "std-widgets.slint";
import { Separator } from "widgets.slint";

// The top toolbar: file actions and view toggles on the left, zoom controls on
// the right. The toggles are two-way bound to the window's view state (so its
// `changed` handlers still fire); the buttons and zoom controls fire callbacks
// the window forwards to Rust or to the image view.
export component Toolbar inherits HorizontalBox {
    // Working-set size: gates the buttons that need files, and Blink (needs > 1).
    in property <int> file-count;
    in-out property <bool> debayer-enabled;
    in-out property <bool> stretch-enabled;
    in-out property <bool> show-stats;
    in-out property <bool> show-info;
    in-out property <bool> blinking;

    callback add-file();
    callback add-folder();
    callback remove-selected();
    callback clear();
    // The image view's current zoom, and its slider range.
    in property <float> zoom: 1.0;
    in property <float> min-zoom: 0.2;
    in property <float> max-zoom: 10.0;

    callback fit();
    callback actual-size();
    callback zoom-to(float);

    // Push externally-driven zooms (Fit, 1:1, a newly loaded frame) onto the
    // slider. Assigning `value` does not re-enter `changed` — the widget only
    // fires that from its own `set-value` — so this cannot loop.
    changed zoom => {
        zoom-slider.value = root.zoom;
    }

    padding: 8px;
    spacing: 8px;

    Button {
        text: "Add File…";
        clicked => {
            root.add-file();
        }
    }
    Button {
        text: "Add Folder…";
        clicked => {
            root.add-folder();
        }
    }
    Button {
        text: "Remove";
        enabled: root.file-count > 0;
        clicked => {
            root.remove-selected();
        }
    }
    Button {
        text: "Clear";
        enabled: root.file-count > 0;
        clicked => {
            root.clear();
        }
    }
    Separator { }
    CheckBox {
        text: "Debayer";
        checked <=> root.debayer-enabled;
    }
    CheckBox {
        text: "Stretch";
        checked <=> root.stretch-enabled;
    }
    Separator { }
    CheckBox {
        text: "Stats";
        checked <=> root.show-stats;
    }
    CheckBox {
        text: "Info";
        checked <=> root.show-info;
    }
    Separator { }
    Button {
        text: "Blink";
        checkable: true;
        checked <=> root.blinking;
        enabled: root.file-count > 1;
    }

    Rectangle {
        horizontal-stretch: 1;
    }

    Button {
        text: "Fit";
        clicked => {
            root.fit();
        }
    }
    Button {
        text: "1:1";
        clicked => {
            root.actual-size();
        }
    }
    zoom-slider := Slider {
        width: 120px;
        minimum: root.min-zoom;
        maximum: root.max-zoom;
        value: root.zoom;
        // One-way, so the handler still sees the pre-zoom geometry. Dragging
        // makes the widget assign its own `value`, which drops any binding we
        // put here — hence the `changed zoom` handler below rather than a
        // binding, to keep Fit / 1:1 reflected on the slider.
        changed(v) => {
            root.zoom-to(v);
        }
    }
    Text {
        text: round(root.zoom * 10) / 10 + "x";
        width: 40px;
        vertical-alignment: center;
    }
}

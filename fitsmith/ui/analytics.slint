import { Button, ComboBox, Slider } from "std-widgets.slint";
import { DialogCard } from "dialog.slint";
import { AnalyticsChart } from "chart.slint";
import { ChartPoint, ChartTick } from "types.slint";

// The chart modal behind both Tools ▸ Analytics… and Tools ▸ Star metrics…:
// plots one metric across the checked working-set files, ordered by acquisition
// time (DATE-OBS). The two differ only in their title, which metrics they list,
// whether their batch detects stars, and their export file-name prefix — all of
// which are the controller's business. Purely presentational — the controller
// computes every metric per file once, then feeds normalized chart data;
// switching the metric dropdown re-plots with no file re-read.
export component AnalyticsDialog inherits DialogCard {
    // Names the dialog: which of the two this is.
    in property <string> title-text;
    // The selectable metrics, supplied by the controller from
    // `libfitz::analytics::Metric::of_family()`; `metric-index` indexes into
    // that family's list.
    in property <[string]> metric-model;
    // Chart data (see AnalyticsChart / ChartPoint for the coordinate space).
    in property <[ChartPoint]> points;
    in property <[ChartTick]> x-ticks;
    in property <[ChartTick]> y-ticks;
    in property <string> line-commands;
    in property <string> metric-label;
    // How many frames made it onto the plot, and how many were skipped
    // (no parseable DATE-OBS / already-debayered RGB).
    in property <int> plotted-count;
    in property <int> skipped-no-date;
    in property <int> skipped-not-mono;
    // Frames that analyzed fine but have no value for the plotted metric,
    // already worded by the controller (e.g. "2 with no stars detected").
    // A built string rather than an int like its `skipped-*` neighbours because
    // the wording is family-specific — "no stars detected" means nothing in the
    // Analytics dialog — and a presentational component should not branch on a
    // family it cannot see. Empty when there are none.
    in property <string> unavailable-note;
    in-out property <int> metric-index;
    // 1.0 = fit to width … 4.0 = 4x, scrolled horizontally. The slider
    // clamps to that range on its own.
    in-out property <float> zoom: 1.0;

    callback metric-changed(int);
    callback export-svg();
    callback export-csv();

    // Resizable: the chart is the point of this dialog, and a longer session
    // wants more plot. The parent owns `card-width`/`card-height` so a resize
    // outlives a close/reopen; the minimum keeps the metric row, the chart and
    // the footer buttons all usable.
    resizable: true;
    min-card-width: 560px;
    min-card-height: 400px;

    VerticalLayout {
        padding: 24px;
        spacing: 12px;

        Text {
            text: root.title-text;
            font-size: 20px;
            font-weight: 700;
            color: white;
        }

        // Metric selector on the left, zoom control on the right.
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Metric:";
                color: #c8c8c8;
                vertical-alignment: center;
            }
            ComboBox {
                model: root.metric-model;
                current-index <=> root.metric-index;
                selected => {
                    root.metric-changed(self.current-index);
                }
            }
            Rectangle {
                horizontal-stretch: 1;
            }
            Text {
                text: "Zoom:";
                color: #c8c8c8;
                vertical-alignment: center;
            }
            Slider {
                width: 140px;
                minimum: 1.0;
                maximum: 4.0;
                value <=> root.zoom;
            }
            Text {
                text: round(root.zoom * 10) / 10 + "x";
                color: #c8c8c8;
                width: 34px;
                vertical-alignment: center;
            }
        }

        chart := AnalyticsChart {
            vertical-stretch: 1;
            points: root.points;
            x-ticks: root.x-ticks;
            y-ticks: root.y-ticks;
            line-commands: root.line-commands;
            metric-label: root.metric-label;
            zoom: root.zoom;
        }

        Text {
            text: root.plotted-count + " plotted"
                + (root.skipped-no-date > 0
                    ? ", " + root.skipped-no-date + " skipped (no DATE-OBS)" : "")
                + (root.skipped-not-mono > 0
                    ? ", " + root.skipped-not-mono + " skipped (not mono)" : "")
                + (root.unavailable-note != "" ? ", " + root.unavailable-note : "");
            color: #a0a0a0;
            font-size: 12px;
        }

        HorizontalLayout {
            spacing: 8px;
            Button {
                text: "Export SVG";
                enabled: root.plotted-count > 0;
                clicked => {
                    root.export-svg();
                }
            }
            Button {
                text: "Export CSV";
                enabled: root.plotted-count > 0;
                clicked => {
                    root.export-csv();
                }
            }
            Rectangle {
                horizontal-stretch: 1;
            }
            Button {
                text: "Close";
                primary: true;
                clicked => {
                    root.cancel();
                }
            }
        }
    }
}

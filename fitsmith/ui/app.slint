import { Button, CheckBox, HorizontalBox, VerticalBox, TabWidget, Spinner } from "std-widgets.slint";
import { FileRow, HeaderRow, StatItem } from "types.slint";
import { ImageView } from "image_view.slint";
import { FileList } from "file_list.slint";
import { StatsPanel } from "stats_panel.slint";
import { InfoPanel } from "info_panel.slint";
import { HeaderView } from "header_view.slint";
import { AboutDialog } from "about.slint";
import { CompressDialog, DecompressDialog } from "operation.slint";
import { ConfirmDialog } from "confirm.slint";

// Re-export the shared structs so the generated Rust names them at the crate root.
export { FileRow, HeaderRow, StatItem }

// A thin vertical divider between toolbar / status-bar groups.
component Separator inherits Rectangle {
    width: 1px;
    background: #444444;
}

export component AppWindow inherits Window {
    in property <image> preview-image;
    in property <length> image-width;
    in property <length> image-height;
    in property <[FileRow]> files;
    in property <int> selected-index: -1;
    in-out property <bool> debayer-enabled: true;
    in-out property <bool> stretch-enabled: true;
    in-out property <bool> blinking: false;
    // The stats and info panels dock in the same spot and are mutually
    // exclusive — turning one on turns the other off (see the `changed`
    // handlers below).
    in-out property <bool> show-stats: false;
    in-out property <bool> show-info: false;
    in property <bool> busy: false;
    // Draggable split between the file list and the image/headers panel. Stored
    // as the file list's width; clamped to the min widths below at layout time.
    in-out property <length> file-list-width: 240px;
    // FITS header cards for the Headers tab.
    in property <[HeaderRow]> header-rows;
    // Pixel statistics (empty for an already-debayered RGB cube) and the
    // matching 0..1 histogram bar heights for the stats panel.
    in property <[StatItem]> stats;
    in property <[float]> histogram;
    // Curated metadata summary (label/value pairs, as `fitz info` reports) for
    // the info panel.
    in property <[StatItem]> info;
    // Status bar: the high-level activity (loading, blinking…), the fine-grained
    // pipeline step (reading, debayering, stretching), and the cache memory use.
    in property <string> status-text;
    in property <string> stage-text;
    in property <string> memory-text;
    // App version (set from Cargo's package version) for the About dialog.
    in property <string> app-version;
    // Whether the Help ▸ About overlay is showing.
    in-out property <bool> show-about: false;
    // Whether the "clear the working set?" confirmation is showing.
    in-out property <bool> show-clear-confirm: false;

    // Edit ▸ Compress… / Decompress… dialogs. Only one shows at a time.
    // `op-*` are the shared dialog settings; the counts say how many working-set
    // files each operation will touch (the checked rows, or all when none are
    // checked). Rust fills the counts and resets the settings before showing.
    in-out property <bool> show-compress: false;
    in-out property <bool> show-decompress: false;
    in property <int> compress-count;
    in property <int> decompress-count;
    in-out property <int> op-algorithm: 0;
    in-out property <bool> op-keep-source: true;
    in-out property <bool> op-use-custom-dir: false;
    in-out property <string> op-output-dir: "";

    callback open();
    callback open-directory();
    callback clear-files();
    // Remove the checked rows (or the highlighted one when none are checked).
    callback remove-selected();
    // Check / uncheck every row in the working set.
    callback select-all();
    callback deselect-all();
    callback request-exit();
    callback select-file(int);
    // Toggle a row's checkbox (selection) state — by index into the file list.
    callback toggle-check(int);
    // Keyboard navigation from the file list: relative move, and jump to ends.
    callback navigate(int);
    callback navigate-first();
    callback navigate-last();
    callback blink-toggled();
    // Fired when a view toggle changes so Rust can re-render the cached image.
    callback toggles-changed();
    // Edit menu: Rust computes the file count and resets the dialog
    // settings, then shows the matching dialog.
    callback open-compress-dialog();
    callback open-decompress-dialog();
    // Open the native folder picker for the "different directory" field.
    callback browse-output-dir();
    // Run the operation with the current `op-*` settings.
    callback run-compress();
    callback run-decompress();

    changed debayer-enabled => {
        root.toggles-changed();
    }
    changed stretch-enabled => {
        root.toggles-changed();
    }
    changed blinking => {
        root.blink-toggled();
    }
    // Stats and info share the dock, so only one shows at a time. The `if`
    // guards stop the paired reset (setting the other to false) from bouncing
    // back — a false value doesn't re-trigger these handlers.
    changed show-stats => {
        if (root.show-stats) {
            root.show-info = false;
        }
    }
    changed show-info => {
        if (root.show-info) {
            root.show-stats = false;
        }
    }

    title: "FitSmith";
    preferred-width: 1000px;
    preferred-height: 680px;
    // Enough for both min widths (150 + 6 handle + 480) plus window chrome.
    min-width: 660px;
    min-height: 400px;

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "Add File…";
                activated => {
                    root.open();
                }
            }
            MenuItem {
                title: "Add Folder…";
                activated => {
                    root.open-directory();
                }
            }
            MenuItem {
                title: "Remove Selected";
                enabled: root.files.length > 0;
                activated => {
                    root.remove-selected();
                }
            }
            MenuItem {
                title: "Clear";
                enabled: root.files.length > 0;
                activated => {
                    root.show-clear-confirm = true;
                }
            }
            MenuSeparator { }
            MenuItem {
                title: "Exit";
                activated => {
                    root.request-exit();
                }
            }
        }

        Menu {
            title: "View";
            MenuItem {
                title: "Debayer raw";
                checkable: true;
                checked <=> root.debayer-enabled;
            }
            MenuItem {
                title: "Stretch preview";
                checkable: true;
                checked <=> root.stretch-enabled;
            }
            MenuItem {
                title: "Show image stats";
                checkable: true;
                checked <=> root.show-stats;
            }
            MenuItem {
                title: "Show image info";
                checkable: true;
                checked <=> root.show-info;
            }
            MenuSeparator { }
            MenuItem {
                title: "Blink";
                checkable: true;
                checked <=> root.blinking;
            }
        }

        Menu {
            title: "Edit";
            MenuItem {
                title: "Select All";
                enabled: root.files.length > 0;
                shortcut: @keys(Control + A);
                activated => {
                    root.select-all();
                }
            }
            MenuItem {
                title: "Deselect All";
                enabled: root.files.length > 0;
                shortcut: @keys(Control + D);
                activated => {
                    root.deselect-all();
                }
            }
            MenuSeparator { }
            MenuItem {
                title: "Compress…";
                enabled: root.files.length > 0;
                activated => {
                    root.open-compress-dialog();
                }
            }
            MenuItem {
                title: "Decompress…";
                enabled: root.files.length > 0;
                activated => {
                    root.open-decompress-dialog();
                }
            }
        }

        Menu {
            title: "Help";
            MenuItem {
                title: "About FitSmith";
                activated => {
                    root.show-about = true;
                }
            }
        }
    }

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Toolbar: file + view toggles on the left, zoom controls on the right.
        HorizontalBox {
            padding: 8px;
            spacing: 8px;

            Button {
                text: "Add File…";
                clicked => {
                    root.open();
                }
            }
            Button {
                text: "Add Folder…";
                clicked => {
                    root.open-directory();
                }
            }
            Button {
                text: "Remove";
                enabled: root.files.length > 0;
                clicked => {
                    root.remove-selected();
                }
            }
            Button {
                text: "Clear";
                enabled: root.files.length > 0;
                clicked => {
                    root.show-clear-confirm = true;
                }
            }
            Separator { }
            CheckBox {
                text: "Debayer";
                checked <=> root.debayer-enabled;
            }
            CheckBox {
                text: "Stretch";
                checked <=> root.stretch-enabled;
            }
            Separator { }
            CheckBox {
                text: "Stats";
                checked <=> root.show-stats;
            }
            CheckBox {
                text: "Info";
                checked <=> root.show-info;
            }
            Separator { }
            Button {
                text: "Blink";
                checkable: true;
                checked <=> root.blinking;
                enabled: root.files.length > 1;
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            Button {
                text: "Fit";
                clicked => {
                    image-view.fit();
                }
            }
            Button {
                text: "1:1";
                clicked => {
                    image-view.actual-size();
                }
            }
            Button {
                text: "−";
                clicked => {
                    image-view.zoom-by(0.8);
                }
            }
            Button {
                text: "+";
                clicked => {
                    image-view.zoom-by(1.25);
                }
            }
        }

        // Left: file list. A draggable handle. Right: the image / headers tabs.
        // Positioned manually (not via a layout) so the split width is honored
        // exactly and clamped to each side's minimum.
        split := Rectangle {
            vertical-stretch: 1;

            property <length> handle-w: 6px;
            property <length> min-list: 150px;
            property <length> min-image: 480px;
            property <length> max-list: max(self.min-list, self.width - self.handle-w - self.min-image);
            // The effective (clamped) list width used for layout; the stored
            // `file-list-width` is the user's preference.
            property <length> list-w: clamp(root.file-list-width, self.min-list, self.max-list);

            FileList {
                x: 0;
                y: 0;
                width: split.list-w;
                height: parent.height;
                files: root.files;
                selected-index: root.selected-index;
                select(idx) => {
                    root.select-file(idx);
                }
                toggle-check(idx) => {
                    root.toggle-check(idx);
                }
                select-relative(delta) => {
                    root.navigate(delta);
                }
                select-first() => {
                    root.navigate-first();
                }
                select-last() => {
                    root.navigate-last();
                }
            }

            // Splitter handle: drag to reallocate width.
            Rectangle {
                x: split.list-w;
                y: 0;
                width: split.handle-w;
                height: parent.height;
                background: handle-touch.pressed || handle-touch.has-hover ? #4a4a4a : #333333;
                handle-touch := TouchArea {
                    mouse-cursor: ew-resize;
                    moved => {
                        // pressed-x is fixed for the drag; mouse-x follows the
                        // cursor, so the handle tracks it keeping the grab offset.
                        root.file-list-width = clamp(
                            split.list-w + (self.mouse-x - self.pressed-x),
                            split.min-list, split.max-list);
                    }
                }
            }

            TabWidget {
                x: split.list-w + split.handle-w;
                y: 0;
                width: parent.width - split.list-w - split.handle-w;
                height: parent.height;

                Tab {
                    title: "Image";
                    VerticalLayout {
                        image-view := ImageView {
                            vertical-stretch: 1;
                            source: root.preview-image;
                            natural-width: root.image-width;
                            natural-height: root.image-height;
                        }
                        // Docks below the image when "Stats" or "Info" is on
                        // (mutually exclusive), shrinking the image area to fit.
                        if root.show-stats: StatsPanel {
                            stats: root.stats;
                            histogram: root.histogram;
                        }
                        if root.show-info: InfoPanel {
                            info: root.info;
                        }
                    }
                }

                Tab {
                    title: "Headers";
                    HeaderView {
                        rows: root.header-rows;
                    }
                }
            }
        }

        // Status bar: global activity on the left, then a separator and the
        // pipeline step (only while one is running), and cache memory use pinned
        // to the far right.
        HorizontalBox {
            padding: 6px;
            spacing: 8px;
            // A live spinner while a load/render is in flight.
            if root.busy: Spinner {
                width: 14px;
                height: 14px;
                indeterminate: true;
            }
            Text {
                text: root.status-text;
                overflow: elide;
                vertical-alignment: center;
            }
            // Separator + action step, shown only while a pipeline step runs.
            if root.stage-text != "": Separator { }
            if root.stage-text != "": Text {
                text: root.stage-text;
                color: #a0a0a0;
                overflow: elide;
                vertical-alignment: center;
                horizontal-alignment: left;
            }
            // Absorb the slack so memory use sits on the far right.
            Rectangle {
                horizontal-stretch: 1;
            }
            Text {
                text: root.memory-text;
                color: #a0a0a0;
                vertical-alignment: center;
                horizontal-alignment: right;
            }
        }
    }

    // The About overlay sits above the main content (declared last, so it stacks
    // on top) and fills the window when shown.
    if root.show-about: AboutDialog {
        width: 100%;
        height: 100%;
        version: root.app-version;
        close => {
            root.show-about = false;
        }
    }

    // Guard the destructive "Clear" with a confirmation — the working set is
    // only emptied once the user agrees.
    if root.show-clear-confirm: ConfirmDialog {
        width: 100%;
        height: 100%;
        title: "Clear working set?";
        message: "Remove all " + root.files.length + " files from the list? This doesn't delete them from disk.";
        confirm-text: "Clear";
        confirm => {
            root.show-clear-confirm = false;
            root.clear-files();
        }
        cancel => {
            root.show-clear-confirm = false;
        }
    }

    // The Edit dialogs stack above the main content the same way. They bind
    // the shared `op-*` settings and hand the confirm off to Rust; Cancel (and a
    // scrim click) just hides them.
    if root.show-compress: CompressDialog {
        width: 100%;
        height: 100%;
        file-count: root.compress-count;
        algorithm-index <=> root.op-algorithm;
        keep-source <=> root.op-keep-source;
        use-custom-dir <=> root.op-use-custom-dir;
        output-dir <=> root.op-output-dir;
        browse => {
            root.browse-output-dir();
        }
        confirm => {
            root.run-compress();
        }
        cancel => {
            root.show-compress = false;
        }
    }
    if root.show-decompress: DecompressDialog {
        width: 100%;
        height: 100%;
        file-count: root.decompress-count;
        keep-source <=> root.op-keep-source;
        use-custom-dir <=> root.op-use-custom-dir;
        output-dir <=> root.op-output-dir;
        browse => {
            root.browse-output-dir();
        }
        confirm => {
            root.run-decompress();
        }
        cancel => {
            root.show-decompress = false;
        }
    }
}

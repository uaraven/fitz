import { VerticalBox, TabWidget } from "std-widgets.slint";
import { FileRow, HeaderRow, StatItem, ChartPoint, ChartTick } from "types.slint";
import { ImageView } from "image_view.slint";
import { FileList } from "file_list.slint";
import { StatsPanel } from "stats_panel.slint";
import { InfoPanel } from "info_panel.slint";
import { HeaderView } from "header_view.slint";
import { AboutDialog } from "about.slint";
import { CompressDialog, DecompressDialog } from "operation.slint";
import { ExportDialog } from "export.slint";
import { ProgressOverlay } from "dialog.slint";
import { AnalyticsDialog } from "analytics.slint";
import { ConfirmDialog } from "confirm.slint";
import { Toolbar } from "toolbar.slint";
import { StatusBar } from "status_bar.slint";

// Re-export the shared structs so the generated Rust names them at the crate root.
export { FileRow, HeaderRow, StatItem, ChartPoint, ChartTick }

export component AppWindow inherits Window {
    in property <image> preview-image;
    in property <length> image-width;
    in property <length> image-height;
    in property <[FileRow]> files;
    in property <int> selected-index: -1;
    in-out property <bool> debayer-enabled: false;
    in-out property <bool> stretch-enabled: true;
    in-out property <bool> blinking: false;
    // The stats and info panels dock in the same spot and are mutually
    // exclusive — turning one on turns the other off (see the `changed`
    // handlers below).
    in-out property <bool> show-stats: false;
    in-out property <bool> show-info: false;
    in property <bool> busy: false;
    // Draggable split between the file list and the image/headers panel. Stored
    // as the file list's width; clamped to the min widths below at layout time.
    in-out property <length> file-list-width: 240px;
    // FITS header cards for the Headers tab.
    in property <[HeaderRow]> header-rows;
    // Pixel statistics (empty for an already-debayered RGB cube) and the
    // matching 0..1 histogram bar heights for the stats panel.
    in property <[StatItem]> stats;
    in property <[float]> histogram;
    // Curated metadata summary (label/value pairs, as `fitz info` reports) for
    // the info panel.
    in property <[StatItem]> info;
    // Status bar: the high-level activity (loading, blinking…), the fine-grained
    // pipeline step (reading, debayering, stretching), and the cache memory use.
    in property <string> status-text;
    in property <string> stage-text;
    in property <string> memory-text;
    // App version (set from Cargo's package version) for the About dialog.
    in property <string> app-version;
    // Whether the Help ▸ About overlay is showing.
    in-out property <bool> show-about: false;
    // Whether the "clear the working set?" confirmation is showing.
    in-out property <bool> show-clear-confirm: false;

    // Tools ▸ Compress… / Decompress… dialogs. Only one shows at a time.
    // `op-*` are the shared dialog settings; the counts say how many working-set
    // files each operation will touch (the checked rows, or all when none are
    // checked). Rust fills the counts and resets the settings before showing.
    in-out property <bool> show-compress: false;
    in-out property <bool> show-decompress: false;
    in property <int> compress-count;
    in property <int> decompress-count;
    in-out property <int> op-algorithm: 0;
    in-out property <bool> op-keep-source: true;
    in-out property <bool> op-use-custom-dir: false;
    in-out property <string> op-output-dir: "";

    // View ▸ Export… dialog. `export-count` is how many working-set files the
    // export will touch (the checked rows, or all when none are checked). Rust
    // fills the count and resets the settings before showing. The `export-*`
    // fields are the per-format settings; `export-in-progress`/`export-progress`
    // drive the modal progress overlay while the batch runs.
    in-out property <bool> show-export: false;
    in property <int> export-count;
    in-out property <string> export-output-dir: "";
    in-out property <int> export-format: 0;
    in-out property <int> export-fits-bitpix: 1;
    in-out property <bool> export-fits-compress: false;
    in-out property <int> export-fits-algorithm: 0;
    in-out property <int> export-tiff-bpp: 1;
    in-out property <bool> export-tiff-deflate: false;
    in-out property <int> export-jpeg-quality: 90;
    in property <bool> export-in-progress: false;
    in property <float> export-progress: 0;
    in property <string> export-progress-text: "";

    // The chart dialog behind Tools ▸ Analytics… and Tools ▸ Star metrics…:
    // plot one metric across the checked files ordered by DATE-OBS. Rust
    // computes all of that family's metrics per file once when the dialog
    // opens, then re-fills the chart data on each metric switch (see
    // AnalyticsChart / ChartPoint for the normalized coordinate space).
    //
    // One property set serves both: which family is on screen is the
    // controller's state, and the two dialogs are never open at once. They
    // therefore share a remembered card size too — they are the same dialog.
    in-out property <bool> show-analytics: false;
    in property <string> analytics-title;
    // The dialog's size. Held here rather than in the dialog (which is torn
    // down on close) so a resize survives reopening, like `file-list-width`.
    // The dialog clamps these to its minimum and to the window.
    in-out property <length> analytics-card-width: 760px;
    in-out property <length> analytics-card-height: 540px;
    // Index into `analytics-metric-model`, which the controller fills from
    // `fitz_core::analytics::Metric::of_family()` — so the dropdown order and
    // the plotted metric can't drift apart.
    in property <[string]> analytics-metric-model;
    in-out property <int> analytics-metric;
    in-out property <float> analytics-zoom: 1.0;
    in property <string> analytics-metric-label;
    in property <int> analytics-plotted-count;
    in property <int> analytics-skipped-no-date;
    in property <int> analytics-skipped-not-mono;
    // Frames with no value for the plotted metric, worded by the controller.
    in property <string> analytics-unavailable-note;
    in property <[ChartPoint]> analytics-points;
    in property <string> analytics-line-commands;
    in property <[ChartTick]> analytics-x-ticks;
    in property <[ChartTick]> analytics-y-ticks;
    // The batch that feeds the dialog: these drive the cancellable progress
    // overlay while the files are read and measured, before the dialog shows.
    in property <bool> analytics-in-progress: false;
    in property <float> analytics-progress: 0;
    in property <string> analytics-progress-text: "";

    callback open();
    callback open-directory();
    callback clear-files();
    // Remove the checked rows (or the highlighted one when none are checked).
    callback remove-selected();
    // Check / uncheck every row in the working set.
    callback select-all();
    callback deselect-all();
    callback request-exit();
    callback select-file(int);
    // Toggle a row's checkbox (selection) state — by index into the file list.
    callback toggle-check(int);
    // Keyboard navigation from the file list: relative move, and jump to ends.
    callback navigate(int);
    callback navigate-first();
    callback navigate-last();
    callback blink-toggled();
    // Fired when a view toggle changes so Rust can re-render the cached image.
    callback toggles-changed();
    // Tools menu: Rust computes the file count and resets the dialog
    // settings, then shows the matching dialog.
    callback open-compress-dialog();
    callback open-decompress-dialog();
    // Open the native folder picker for the "different directory" field.
    callback browse-output-dir();
    // Run the operation with the current `op-*` settings.
    callback run-compress();
    callback run-decompress();
    // View ▸ Export: Rust computes the file count and resets the dialog
    // settings, then shows it; browse opens the native folder picker for the
    // destination; run-export starts the batch with the current `export-*`
    // settings.
    callback open-export-dialog();
    callback browse-export-dir();
    callback run-export();
    // Tools ▸ Analytics / Tools ▸ Star metrics: Rust gathers the target files,
    // computes that family's metrics off-thread, fills the chart data and shows
    // the dialog. Two entries rather than a mode switch inside one: only the
    // star batch pays for star detection, and a user picks the question from
    // the menu, not from a control in the dialog.
    callback open-analytics-dialog();
    callback open-star-metrics-dialog();
    // Stop the running batch — no dialog opens and nothing is cached.
    callback cancel-analytics();
    // Metric dropdown changed — re-plot from the cached per-file metrics.
    callback analytics-metric-changed(int);
    // Export the chart: SVG re-renders the plotted series as a vector document,
    // CSV writes it as rows. Neither depends on what the dialog is showing, so
    // a zoomed-in chart still exports whole.
    callback analytics-export-svg();
    callback analytics-export-csv();
    // Dialog dismissed — Rust drops the cached per-file metrics.
    callback close-analytics();

    changed debayer-enabled => {
        root.toggles-changed();
    }
    changed stretch-enabled => {
        root.toggles-changed();
    }
    changed blinking => {
        root.blink-toggled();
    }
    // Stats and info share the dock, so only one shows at a time. The `if`
    // guards stop the paired reset (setting the other to false) from bouncing
    // back — a false value doesn't re-trigger these handlers.
    changed show-stats => {
        if (root.show-stats) {
            root.show-info = false;
        }
    }
    changed show-info => {
        if (root.show-info) {
            root.show-stats = false;
        }
    }

    title: "FitSmith";
    preferred-width: 1000px;
    preferred-height: 680px;
    // Enough for both min widths (150 + 6 handle + 480) plus window chrome.
    min-width: 660px;
    min-height: 400px;

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "Add File…";
                activated => {
                    root.open();
                }
            }
            MenuItem {
                title: "Add Folder…";
                activated => {
                    root.open-directory();
                }
            }
            MenuItem {
                title: "Remove Selected";
                enabled: root.files.length > 0;
                activated => {
                    root.remove-selected();
                }
            }
            MenuItem {
                title: "Clear";
                enabled: root.files.length > 0;
                activated => {
                    root.show-clear-confirm = true;
                }
            }
            MenuSeparator { }
            MenuItem {
                title: "Exit";
                activated => {
                    root.request-exit();
                }
            }
        }

        Menu {
            title: "View";
            MenuItem {
                title: "Debayer raw";
                checkable: true;
                checked <=> root.debayer-enabled;
            }
            MenuItem {
                title: "Stretch preview";
                checkable: true;
                checked <=> root.stretch-enabled;
            }
            MenuItem {
                title: "Show image stats";
                checkable: true;
                checked <=> root.show-stats;
            }
            MenuItem {
                title: "Show image info";
                checkable: true;
                checked <=> root.show-info;
            }
            MenuSeparator { }
            MenuItem {
                title: "Blink";
                checkable: true;
                checked <=> root.blinking;
            }
        }

        Menu {
            title: "Tools";
            MenuItem {
                title: "Select All";
                enabled: root.files.length > 0;
                shortcut: @keys(Control + A);
                activated => {
                    root.select-all();
                }
            }
            MenuItem {
                title: "Deselect All";
                enabled: root.files.length > 0;
                shortcut: @keys(Control + D);
                activated => {
                    root.deselect-all();
                }
            }
            MenuSeparator { }
            MenuItem {
                title: "Compress…";
                enabled: root.files.length > 0;
                activated => {
                    root.open-compress-dialog();
                }
            }
            MenuItem {
                title: "Decompress…";
                enabled: root.files.length > 0;
                activated => {
                    root.open-decompress-dialog();
                }
            }
            MenuSeparator { }
            MenuItem {
                title: "Export…";
                enabled: root.files.length > 0;
                activated => {
                    root.open-export-dialog();
                }
            }
            MenuSeparator { }
            MenuItem {
                title: "Analytics…";
                enabled: root.files.length > 0;
                activated => {
                    root.open-analytics-dialog();
                }
            }
            MenuItem {
                title: "Star metrics…";
                enabled: root.files.length > 0;
                activated => {
                    root.open-star-metrics-dialog();
                }
            }
        }

        Menu {
            title: "Help";
            MenuItem {
                title: "About FitSmith";
                activated => {
                    root.show-about = true;
                }
            }
        }
    }

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Toolbar: file + view toggles on the left, zoom controls on the right.
        // The toggles two-way bind the window's view state; the zoom callbacks
        // drive the image view directly.
        Toolbar {
            file-count: root.files.length;
            debayer-enabled <=> root.debayer-enabled;
            stretch-enabled <=> root.stretch-enabled;
            show-stats <=> root.show-stats;
            show-info <=> root.show-info;
            blinking <=> root.blinking;
            add-file => {
                root.open();
            }
            add-folder => {
                root.open-directory();
            }
            remove-selected => {
                root.remove-selected();
            }
            clear => {
                root.show-clear-confirm = true;
            }
            fit => {
                image-view.fit();
            }
            actual-size => {
                image-view.actual-size();
            }
            zoom-in => {
                image-view.zoom-by(1.25);
            }
            zoom-out => {
                image-view.zoom-by(0.8);
            }
        }

        // Left: file list. A draggable handle. Right: the image / headers tabs.
        // Positioned manually (not via a layout) so the split width is honored
        // exactly and clamped to each side's minimum.
        split := Rectangle {
            vertical-stretch: 1;

            property <length> handle-w: 6px;
            property <length> min-list: 150px;
            property <length> min-image: 480px;
            property <length> max-list: max(self.min-list, self.width - self.handle-w - self.min-image);
            // The effective (clamped) list width used for layout; the stored
            // `file-list-width` is the user's preference.
            property <length> list-w: clamp(root.file-list-width, self.min-list, self.max-list);

            FileList {
                x: 0;
                y: 0;
                width: split.list-w;
                height: parent.height;
                files: root.files;
                selected-index: root.selected-index;
                select(idx) => {
                    root.select-file(idx);
                }
                toggle-check(idx) => {
                    root.toggle-check(idx);
                }
                select-relative(delta) => {
                    root.navigate(delta);
                }
                select-first() => {
                    root.navigate-first();
                }
                select-last() => {
                    root.navigate-last();
                }
            }

            // Splitter handle: drag to reallocate width.
            Rectangle {
                x: split.list-w;
                y: 0;
                width: split.handle-w;
                height: parent.height;
                background: handle-touch.pressed || handle-touch.has-hover ? #4a4a4a : #333333;
                handle-touch := TouchArea {
                    mouse-cursor: ew-resize;
                    moved => {
                        // pressed-x is fixed for the drag; mouse-x follows the
                        // cursor, so the handle tracks it keeping the grab offset.
                        root.file-list-width = clamp(
                            split.list-w + (self.mouse-x - self.pressed-x),
                            split.min-list, split.max-list);
                    }
                }
            }

            TabWidget {
                x: split.list-w + split.handle-w;
                y: 0;
                width: parent.width - split.list-w - split.handle-w;
                height: parent.height;

                Tab {
                    title: "Image";
                    VerticalLayout {
                        image-view := ImageView {
                            vertical-stretch: 1;
                            source: root.preview-image;
                            natural-width: root.image-width;
                            natural-height: root.image-height;
                        }
                        // Docks below the image when "Stats" or "Info" is on
                        // (mutually exclusive), shrinking the image area to fit.
                        if root.show-stats: StatsPanel {
                            stats: root.stats;
                            histogram: root.histogram;
                        }
                        if root.show-info: InfoPanel {
                            info: root.info;
                        }
                    }
                }

                Tab {
                    title: "Headers";
                    HeaderView {
                        rows: root.header-rows;
                    }
                }
            }
        }

        // Status bar: global activity on the left, the pipeline step (only while
        // one is running), and cache memory use pinned to the far right.
        StatusBar {
            busy: root.busy;
            status-text: root.status-text;
            stage-text: root.stage-text;
            memory-text: root.memory-text;
        }
    }

    // The About overlay sits above the main content (declared last, so it stacks
    // on top) and fills the window when shown.
    if root.show-about: AboutDialog {
        width: 100%;
        height: 100%;
        version: root.app-version;
        close => {
            root.show-about = false;
        }
    }

    // Guard the destructive "Clear" with a confirmation — the working set is
    // only emptied once the user agrees.
    if root.show-clear-confirm: ConfirmDialog {
        width: 100%;
        height: 100%;
        title: "Clear working set?";
        message: "Remove all " + root.files.length + " files from the list? This doesn't delete them from disk.";
        confirm-text: "Clear";
        confirm => {
            root.show-clear-confirm = false;
            root.clear-files();
        }
        cancel => {
            root.show-clear-confirm = false;
        }
    }

    // The Tools dialogs stack above the main content the same way. They bind
    // the shared `op-*` settings and hand the confirm off to Rust; Cancel (and a
    // scrim click) just hides them.
    if root.show-compress: CompressDialog {
        width: 100%;
        height: 100%;
        file-count: root.compress-count;
        algorithm-index <=> root.op-algorithm;
        keep-source <=> root.op-keep-source;
        use-custom-dir <=> root.op-use-custom-dir;
        output-dir <=> root.op-output-dir;
        browse => {
            root.browse-output-dir();
        }
        confirm => {
            root.run-compress();
        }
        cancel => {
            root.show-compress = false;
        }
    }
    if root.show-decompress: DecompressDialog {
        width: 100%;
        height: 100%;
        file-count: root.decompress-count;
        keep-source <=> root.op-keep-source;
        use-custom-dir <=> root.op-use-custom-dir;
        output-dir <=> root.op-output-dir;
        browse => {
            root.browse-output-dir();
        }
        confirm => {
            root.run-decompress();
        }
        cancel => {
            root.show-decompress = false;
        }
    }

    // The Export dialog, and the progress overlay shown while its batch runs.
    if root.show-export: ExportDialog {
        width: 100%;
        height: 100%;
        file-count: root.export-count;
        output-dir <=> root.export-output-dir;
        format-index <=> root.export-format;
        fits-bitpix-index <=> root.export-fits-bitpix;
        fits-compress <=> root.export-fits-compress;
        fits-algorithm-index <=> root.export-fits-algorithm;
        tiff-bpp-index <=> root.export-tiff-bpp;
        tiff-deflate <=> root.export-tiff-deflate;
        jpeg-quality <=> root.export-jpeg-quality;
        browse => {
            root.browse-export-dir();
        }
        confirm => {
            root.run-export();
        }
        cancel => {
            root.show-export = false;
        }
    }
    if root.export-in-progress: ProgressOverlay {
        width: 100%;
        height: 100%;
        title: "Exporting…";
        progress: root.export-progress;
        message: root.export-progress-text;
    }

    // Shown while the analytics batch reads and measures the target files.
    // Cancellable: it can run over the whole working set, and unlike an export
    // it writes nothing, so stopping part-way leaves nothing half-done.
    if root.analytics-in-progress: ProgressOverlay {
        width: 100%;
        height: 100%;
        title: "Analyzing…";
        progress: root.analytics-progress;
        message: root.analytics-progress-text;
        cancellable: true;
        cancel => {
            root.cancel-analytics();
        }
    }

    // The Analytics dialog: chart data comes straight from the `analytics-*`
    // props; Close (and a scrim click) hides it and lets Rust drop its cache.
    if root.show-analytics: AnalyticsDialog {
        width: 100%;
        height: 100%;
        title-text: root.analytics-title;
        card-width <=> root.analytics-card-width;
        card-height <=> root.analytics-card-height;
        metric-model: root.analytics-metric-model;
        points: root.analytics-points;
        x-ticks: root.analytics-x-ticks;
        y-ticks: root.analytics-y-ticks;
        line-commands: root.analytics-line-commands;
        metric-label: root.analytics-metric-label;
        plotted-count: root.analytics-plotted-count;
        skipped-no-date: root.analytics-skipped-no-date;
        skipped-not-mono: root.analytics-skipped-not-mono;
        unavailable-note: root.analytics-unavailable-note;
        metric-index <=> root.analytics-metric;
        zoom <=> root.analytics-zoom;
        metric-changed(index) => {
            root.analytics-metric-changed(index);
        }
        export-svg => {
            root.analytics-export-svg();
        }
        export-csv => {
            root.analytics-export-csv();
        }
        cancel => {
            root.show-analytics = false;
            root.close-analytics();
        }
    }
}

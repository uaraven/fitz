import { Palette } from "std-widgets.slint";
import { VScrollArea } from "scrolling.slint";
import { FileRow } from "types.slint";

// The working-set file list. Rows are click-to-highlight; the highlighted row
// is drawn with an accent background and drives the preview. Each row also
// carries a checkbox for an independent multi-selection, toggled by clicking
// the box or pressing Space on the highlighted row. Highlighting is driven by
// index so blink, clicks and keyboard navigation all share one path. When
// focused (click a row, or on startup) the list handles arrow / page / home-end
// / space keys:
//   Up / Down          move highlight by one
//   Space              toggle the highlighted row's checkbox
//   PageUp / PageDown  move by a page   (macOS: Option+Up/Down)
//   Home / End         jump to ends     (macOS: Cmd+Up/Down — Cmd maps to the
//                                        `control` modifier on macOS)
export component FileList inherits Rectangle {
    in property <[FileRow]> files;
    in property <int> selected-index;
    callback select(int);
    callback select-relative(int);
    callback select-first();
    callback select-last();
    // Toggle a row's checkbox (selection) state — by index into the list.
    callback toggle-check(int);

    property <length> row-height: 30px;
    // Rows that fit in the viewport, for Page Up / Down (at least one).
    property <int> page-size: max(1, floor(self.height / root.row-height));

    // Error-row and tooltip colors, keyed on the active color scheme: a dark
    // muted red on dark themes, a pale red on light ones.
    property <bool> dark-theme: Palette.color-scheme == ColorScheme.dark;
    property <color> err-bg: root.dark-theme ? #4d2020 : #f7d6d6;
    property <color> err-hover: root.dark-theme ? #612a2a : #f2bcbc;
    property <color> err-text: root.dark-theme ? white : #601818;
    property <color> tip-bg: root.dark-theme ? #2b2b2b : #fbfbfb;
    property <color> tip-fg: root.dark-theme ? #e0e0e0 : #202020;
    property <color> tip-border: root.dark-theme ? #555555 : #cccccc;

    background: #262626;
    forward-focus: fs;

    fs := FocusScope {
        init => {
            self.focus();
        }
        key-pressed(event) => {
            // Home / End (macOS: Cmd = the `control` modifier).
            if (event.text == Key.Home || (event.text == Key.UpArrow && event.modifiers.control)) {
                root.select-first();
                return accept;
            }
            if (event.text == Key.End || (event.text == Key.DownArrow && event.modifiers.control)) {
                root.select-last();
                return accept;
            }
            // Page Up / Down (macOS: Option = the `alt` modifier).
            if (event.text == Key.PageUp || (event.text == Key.UpArrow && event.modifiers.alt)) {
                root.select-relative(-root.page-size);
                return accept;
            }
            if (event.text == Key.PageDown || (event.text == Key.DownArrow && event.modifiers.alt)) {
                root.select-relative(root.page-size);
                return accept;
            }
            // Space toggles the highlighted row's checkbox (selection).
            if (event.text == Key.Space) {
                if (root.selected-index >= 0) {
                    root.toggle-check(root.selected-index);
                }
                return accept;
            }
            // Single step through the list.
            if (event.text == Key.UpArrow) {
                root.select-relative(-1);
                return accept;
            }
            if (event.text == Key.DownArrow) {
                root.select-relative(1);
                return accept;
            }
            return reject;
        }

        list := VScrollArea {
            content-height: root.files.length * root.row-height;
            for row[idx] in root.files: rowrect := Rectangle {
                property <bool> is-error: row.error != "";
                property <bool> selected: idx == root.selected-index;
                y: idx * root.row-height;
                width: list.content-width;
                height: root.row-height;
                background: self.selected
                    ? #0a5ea8
                    : (self.is-error
                        ? (touch.has-hover ? root.err-hover : root.err-bg)
                        : (touch.has-hover ? #333333 : transparent));
                touch := TouchArea {
                    clicked => {
                        fs.focus();
                        root.select(idx);
                    }
                    // Show the failure reason as a tooltip while hovering an
                    // errored row; hide it as soon as the cursor leaves.
                    changed has-hover => {
                        if (self.has-hover && rowrect.is-error) {
                            tooltip.show();
                        } else {
                            tooltip.close();
                        }
                    }
                }
                // Checkbox, name on the left, an optional status badge on the
                // right — one line.
                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 6px;
                    // A small checkbox reflecting the row's selection state. Its
                    // own TouchArea sits above the row's, so ticking a box does
                    // not change which row is highlighted.
                    VerticalLayout {
                        alignment: center;
                        checkbox := Rectangle {
                            width: 16px;
                            height: 16px;
                            border-width: 1px;
                            border-radius: 3px;
                            border-color: row.checked ? #0a5ea8 : #8a8a8a;
                            background: row.checked ? #0a5ea8 : transparent;
                            Text {
                                text: "✓";
                                visible: row.checked;
                                font-size: 12px;
                                color: white;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                clicked => {
                                    root.toggle-check(idx);
                                }
                            }
                        }
                    }
                    Text {
                        text: row.name;
                        overflow: elide;
                        // Dark text keeps the name legible on the pale-red error
                        // background used by light themes; white everywhere else.
                        color: rowrect.is-error && !rowrect.selected ? root.err-text : white;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: row.status;
                        visible: row.status != "";
                        font-size: 11px;
                        color: row.status == "error" ? #ff8080 : #a0a0a0;
                        vertical-alignment: center;
                    }
                }

                // Hover tooltip carrying the load error. A PopupWindow renders in
                // a top-level overlay, so it isn't clipped by the (narrow) list.
                tooltip := PopupWindow {
                    x: 12px;
                    y: root.row-height - 2px;
                    Rectangle {
                        width: 280px;
                        background: root.tip-bg;
                        border-width: 1px;
                        border-color: root.tip-border;
                        border-radius: 4px;
                        VerticalLayout {
                            padding: 8px;
                            Text {
                                text: row.error;
                                wrap: word-wrap;
                                font-size: 12px;
                                color: root.tip-fg;
                            }
                        }
                    }
                }
            }
        }
    }
}

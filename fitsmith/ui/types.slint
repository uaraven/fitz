// Data structs shared between the Rust controller and the UI.

// One entry in the file list: its display name, a short status badge
// ("compressed" / "error" / ""), the full path, and — when the file failed
// to load — the error message (empty otherwise), shown as a hover tooltip.
// `checked` is the row's independent selection state (its checkbox), separate
// from the single highlighted/previewed row tracked by `selected-index`.
export struct FileRow {
    name: string,
    status: string,
    path: string,
    error: string,
    checked: bool,
}

// One FITS header card, split into the Headers tab's display columns.
export struct HeaderRow {
    keyword: string,
    value: string,
    comment: string,
}

// One labeled statistic in the stats panel (e.g. "mean" / "1234.5").
export struct StatItem {
    label: string,
    value: string,
}

// One sample on the analytics chart. `x`/`y` are screen-normalized 0..1
// coordinates within the plot area — (0, 0) is the top-left corner, so the
// controller maps time to `x` and (inverted) metric value to `y`; the Slint
// side stays layout-only. The labels feed the hover tooltip.
export struct ChartPoint {
    x: float,
    y: float,
    time-label: string,
    value-label: string,
}

// One axis tick: a screen-normalized 0..1 position along its axis (measured
// from the left for X, from the top for Y — same convention as ChartPoint)
// and the label to draw there.
//
// An X tick draws on two lines: `date-label` above `label`. The date is set
// only on the first tick and wherever the local date rolls over, so a single
// night doesn't repeat it under every tick; it is empty everywhere else, and on
// every Y tick. The empty line is still laid out, keeping all the times on one
// row.
export struct ChartTick {
    pos: float,
    label: string,
    date-label: string,
}

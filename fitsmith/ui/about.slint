import { Button } from "std-widgets.slint";

// The Help ▸ About overlay. Fills the whole window with a dimmed scrim (click to
// dismiss) and a centered card. Purely presentational — the parent toggles its
// visibility and feeds the version string; there is no Rust callback beyond the
// close signal.
export component AboutDialog inherits Rectangle {
    in property <string> version;
    callback close();

    // Dim the window behind the card; clicking the scrim dismisses.
    background: #000000cc;
    scrim := TouchArea {
        clicked => {
            root.close();
        }
    }

    Rectangle {
        width: 380px;
        height: 240px;
        background: #2b2b2b;
        border-radius: 10px;
        border-width: 1px;
        border-color: #444444;
        // Swallow clicks on the card so they don't reach the scrim and close it.
        TouchArea { }

        VerticalLayout {
            padding: 28px;
            spacing: 10px;
            alignment: center;

            Text {
                text: "FitSmith";
                font-size: 24px;
                font-weight: 700;
                color: white;
                horizontal-alignment: center;
            }
            Text {
                text: "Version " + root.version;
                color: #a0a0a0;
                horizontal-alignment: center;
            }
            Text {
                text: "A toolset for FITS files";
                color: #c8c8c8;
                wrap: word-wrap;
                horizontal-alignment: center;
            }
            HorizontalLayout {
                alignment: center;
                padding-top: 6px;
                Button {
                    text: "Close";
                    clicked => {
                        root.close();
                    }
                }
            }
        }
    }
}
